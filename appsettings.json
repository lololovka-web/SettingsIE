{
  "Logging": {
    "LogDirectory": "logs",
    "LogFileName": "error.log",
    "MaxLogSizeMB": 10
  },
  "Backup": {
    "DefaultBackupPath": "Desktop",
    "CreateRestorePoint": true
  },
  "Export": {
    "DefaultFormat": "json",
    "DefaultFileName": "WindowsSettings.json"
  },
  "Registry": {
    "IncludeHKCU": true,
    "IncludeHKLM": false,
    "TimeoutSeconds": 30
  }
}
